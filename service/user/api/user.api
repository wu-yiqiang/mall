syntax = "v1"

info (
	title:   "mall "
	desc:    "商城微服务"
	author:  "Sutter"
	email:   "sutter.wu@outlook.com"
	version: "1.0"
)

type SignupRequest {
	UserName string `json:"username"`
	Password string `json:"password"`
	Gender   string `json:"gender",options=male|female|Unknow`
}

type SignupResponse {
	Message string `json:"message"`
}

@server (
	prefix: api
)
service user-api {
	@handler SignupHandler
	post /user/signup (SignupRequest) returns (SignupResponse)
}

